# Ignore Visual Studio specific files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Ignore build outputs
bin/
obj/
out/

# Ignore NuGet packages
*.nupkg
# The packages folder can be ignored if you enable Package Restore
packages/

# Ignore logs, debug files, and temporary files
*.log
*.tlog
*.tmp
*.tmp.*

# Ignore application settings
appsettings.Development.json
appsettings.Local.json
appsettings.*.json

# Ignore database migrations and EF Core files
**/Migrations/

# Ignore Rider/JetBrains specific files
.idea/
*.sln.iml

# Ignore OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Ignore other IDE-specific files
*.vscode/